# Example environment file (DO NOT COMMIT REAL SECRETS)

# Supabase (Anon key is public for client apps, but still avoid committing real values
# if your hosting provider's secrets scanner flags JWT-like strings.)
SUPABASE_URL=<YOUR_SUPABASE_URL>
SUPABASE_ANON_KEY=<YOUR_SUPABASE_ANON_KEY>

# Optional bucket override used by UserProfileService
SUPABASE_USER_PHOTO_BUCKET=user

# PortOne V1 (Iamport) - used by portone_flutter
# V1 "가맹점 식별코드" (often shown as userCode in docs/examples, commonly looks like impXXXXXXXX)
PORTONE_V1_USER_CODE=<YOUR_PORTONE_V1_USER_CODE>

# App mode: when MODE=DEV, the app will prefer *_DEV variables below.
# MODE=DEV

# PortOne V1 PG identifier (example: html5_inicis)
PORTONE_V1_PG=html5_inicis

# Optional DEV overrides (used when MODE=DEV)
# PORTONE_V1_USER_CODE_DEV=<YOUR_TEST_USER_CODE>
# PORTONE_V1_PG_DEV=html5_inicis

# Optional: force a small amount in DEV (integer, KRW)
# PORTONE_V1_TEST_AMOUNT=1000

# PortOne REST API Key / Secret are server-side credentials.
# DO NOT put them in a Flutter client app or in .env (it gets bundled into the app).
# Use a backend (Netlify Function / Supabase Edge Function / your server) for payment verification.
# PORTONE_REST_API_KEY=<SERVER_ONLY>
# PORTONE_REST_API_SECRET=<SERVER_ONLY>

# App URL scheme used to return from external payment apps
PORTONE_APP_SCHEME=esgmobile

# PortOne V2 (storeId + channelKey)
# NOTE: Only relevant if you implement a V2 flow. V1 PGs like html5_inicis cannot be used with V2 checkout.
# PORTONE_V2_STORE_ID=store-00000000-0000-0000-0000-000000000000
# PORTONE_V2_CHANNEL_KEY_DEFAULT=channel-key-00000000-0000-0000-0000-000000000000
# PORTONE_V2_CHANNEL_KEY_INICIS=channel-key-00000000-0000-0000-0000-000000000000
# PORTONE_V2_CHANNEL_KEY_NPAY=channel-key-00000000-0000-0000-0000-000000000000
# PORTONE_V2_PG=inicisV2

# NEVER put the service-role key in a client app.
# SUPABASE_KEY=<DO_NOT_USE_IN_CLIENT>
