# Example environment file (DO NOT COMMIT REAL SECRETS)

# Supabase (Anon key is public for client apps, but still avoid committing real values
# if your hosting provider's secrets scanner flags JWT-like strings.)
SUPABASE_URL=<YOUR_SUPABASE_URL>
SUPABASE_ANON_KEY=<YOUR_SUPABASE_ANON_KEY>

# Optional bucket override used by UserProfileService
SUPABASE_USER_PHOTO_BUCKET=user

# NEVER put the service-role key in a client app.
# SUPABASE_KEY=<DO_NOT_USE_IN_CLIENT>
